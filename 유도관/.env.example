DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DB_NAME
OAUTH_SERVER_URL=https://your-oauth-server.example.com
VITE_APP_ID=your_app_id
JWT_SECRET=replace_with_at_least_16_characters
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# OAuth 콜백 후 브라우저로 돌아갈 주소(기본: Expo Web 8081). web-admin 구글 로그인 시 WEB_ADMIN 권장.
EXPO_WEB_PREVIEW_URL=http://localhost:8081
# web-admin: /api/oauth/google?return=webadmin 로 로그인한 뒤 여기로 #session=JWT 리다이렉트
WEB_ADMIN_POST_LOGIN_URL=http://127.0.0.1:5180

# Optional (owner/admin bootstrap)
OWNER_OPEN_ID=
OWNER_NAME=

# Optional Expo public mirrors
EXPO_PUBLIC_APP_ID=
EXPO_PUBLIC_OAUTH_SERVER_URL=
EXPO_PUBLIC_OAUTH_PORTAL_URL=
