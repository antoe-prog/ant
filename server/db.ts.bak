// ??? Approvals ???????????????????????????????????????????????????????????????

export async function getPendingApprovals(approverId?: number) {
  const db = await getDb();
  if (!db) return [];
  const conditions = [eq(approvals.status, "pending")];
  if (approverId) conditions.push(eq(approvals.approverId, approverId));
  return db
    .select({
      approval: approvals,
      requester: users,
    })
    .from(approvals)
    .innerJoin(users, eq(approvals.requestedBy, users.id))
    .where(and(...conditions))
    .orderBy(desc(approvals.createdAt));
}

export async function getApprovalById(id: number) {
  const db = await getDb();
  if (!db) return null;
  const result = await db
    .select()
    .from(approvals)
    .where(eq(approvals.id, id))
    .limit(1);
  return result[0] ?? null;
}

