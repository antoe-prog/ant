  if (!db) throw new Error("DB not available");
  await db.update(onboardingPlans).set(data).where(eq(onboardingPlans.id, id));
}

export async function recalcCompletionRate(planId: number) {
  const db = await getDb();
  if (!db) return;
  const allTasks = await db
    .select()
    .from(tasks)
    .where(eq(tasks.onboardingPlanId, planId));
  if (allTasks.length === 0) return;
  const completed = allTasks.filter((t) => t.status === "completed").length;
  const rate = Math.round((completed / allTasks.length) * 100);
  const planStatus =
    rate === 100 ? "completed" : rate > 0 ? "in_progress" : "not_started";
  await db
    .update(onboardingPlans)
    .set({ completionRate: rate, status: planStatus })
    .where(eq(onboardingPlans.id, planId));
}

