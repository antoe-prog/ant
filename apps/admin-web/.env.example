# 비워두면 접속한 호스트 기준으로 자동 계산 (예: http://192.168.x.x:8000)
# 고정이 필요할 때만 설정:
# VITE_GATEWAY_URL=http://127.0.0.1:8000

# 도장 API (유도관 Express+tRPC). 앱의 EXPO_PUBLIC_API_BASE_URL 과 동일해야 함.
# 프로덕션 기본: https://api.judokan.store (로컬은 아래처럼 오버라이드)
# VITE_DOJO_API_BASE_URL=https://api.judokan.store
# VITE_DOJO_API_BASE_URL=http://127.0.0.1:3000
