# ─── Expo / 모바일·웹 앱 (빌드 시 번들에 포함) ─────────────────────────────
# 프로덕션 API. 로컬만 쓸 때는 http://127.0.0.1:3000 등으로 바꿉니다.
EXPO_PUBLIC_API_BASE_URL=https://api.judokan.store

# ─── 도장 API 서버 (pnpm dev:server 등) ───────────────────────────────────
PORT=3000
NODE_ENV=development

DATABASE_URL=mysql://user:password@127.0.0.1:3306/your_database
JWT_SECRET=change-this-to-a-long-random-secret

# 프로덕션에서 nginx 등 리버스 프록시 뒤에 둘 때: HTTPS·Secure 쿠키 판별
# NODE_ENV=production
# TRUST_PROXY=1

# 브라우저에서 다른 도메인으로 앱을 띄울 때만 설정 (쉼표 구분). 비우면 요청 Origin을 그대로 허용.
# CORS_ALLOWED_ORIGINS=https://app.judokan.store,https://admin.judokan.store

# 소셜 로그인(선택) — 키 없으면 해당 버튼만 503
# KAKAO_REST_API_KEY=
# INSTAGRAM_APP_ID=
# GOOGLE_CLIENT_ID=
