APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/genai_template
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini
DAILY_BUDGET_USD=2.0
# Optional: comma-separated browser origins (apps/admin-web). Empty = localhost/127.0.0.1:5173 + LAN Vite (:5173) regex for 192.168/10.x
CORS_ALLOW_ORIGINS=

# --- Self-registration (admin-web) ---
# Secret used to sign session tokens. MUST be changed in production.
JWT_SECRET=dev-insecure-change-me
# Where the local JSON user store is written (relative to process cwd).
AUTH_USER_STORE_PATH=./data/users.json
# Session token lifetime in seconds (default 7 days).
AUTH_TOKEN_TTL_SECONDS=604800
# Optional: email that always gets 'admin' role on first registration.
AUTH_BOOTSTRAP_ADMIN_EMAIL=

